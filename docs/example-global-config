# Dippy global config example
#
# Copy this file to ~/.dippy/config (global) or .dippy (project root).
# Global config applies everywhere; project config overrides it locally.
#
# NOTE: Many commands are already handled by Dippy's built-in allowlist
# (~200 read-only commands like ls, cat, grep, jq, etc.) and by
# CLI-specific handlers (git, docker, kubectl, helm, curl, etc.).
# Only add rules for commands that aren't covered or to override defaults.
#
# IMPORTANT: Dippy does NOT support inline comments.
# Comments must be on their own line.

#---- Denied (blocked with AI-readable message) ----#
deny sudo "sudo is blocked. Running as root is never allowed - find a non-root alternative"
deny rm -rf /* "Too dangerous - be more specific"
deny git push --force * "Use --force-with-lease instead"
deny git push -f * "Use --force-with-lease instead"
deny git reset --hard * "Confirm before discarding changes"
# destructive disk write
deny dd if=*
# overly permissive
deny chmod 777 * "Don't use 777 permissions"
# listening socket
deny nc -l * "Don't open listening sockets"
# privileged containers
deny docker run --privileged * "Don't run privileged containers"

# Python: block inline -c (forces writing .py files, better for review)
deny python -c "Write code to a .py file instead of using -c"
deny python3 -c "Write code to a .py file instead of using -c"
deny uv run python -c "Write code to a .py file instead of using -c"
deny uv run python3 -c "Write code to a .py file instead of using -c"

#---- Denied Redirects (file writes blocked) ----#
deny-redirect **/.env* "Never write secrets to env files"
deny-redirect **/*credential* "Never write credentials"
deny-redirect **/*secret* "Never write secrets"
deny-redirect ~/.ssh/id_* "Never overwrite SSH keys"
deny-redirect /etc/** "System config is off-limits"

#---- Ask (require confirmation) ----#
ask-redirect ~/.* "Modifying dotfiles requires review"
ask-redirect **/.config/* "Modifying config files requires review"
ask ssh * "SSH requires confirmation"
ask git push * "Confirm before pushing"

